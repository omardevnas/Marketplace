_ReSharper*/
*.[Rr]e[Ss]harper.user

# JustMock
MockLog.txt

# OpenCover
[Gg]enerated[Ii]nternal[Tt]ypes.cs

# Visual Studio Project User Options
*.csproj.user
*.vbproj.user
*.vcxproj.user
*.sqlproj.user
*.dbproj.user

