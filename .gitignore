## Ignore Visual Studio/Rider temporary files, build results, and
## files generated by popular Visual Studio add-ons.
## See https://github.com/github/gitignore/blob/main/VisualStudio.gitignore

# Build results
[Dd]ebug/
[Dd]ebugPublic/
[Rr]elease/
[Rr]eleases/
x64/
x86/
[Ww][Ii][Nn]32/
[Aa][Rr][Mm]/
[Aa][Rr][Mm]64/
bld/
[Bb]in/
[Oo]bj/
[Ll]og/
[Ll]ogs/

# Visual Studio 2015/2017/2019/2022 cache/options directory
.vs/
# Uncomment if you have tasks that create the project's static files in wwwroot
#wwwroot/lib/

# Visual Studio 2017/2019/2022 auto generated files
Generated\ Files/

# MSTest test Results
[Tt]est[Rr]esult*/
[Bb]uild[Ll]og.*

# NUnit
*.VisualState.xml
TestResult.xml
nunit-agent.log

# Build Results of an extension-specific compilation step
*.variant
*.g.cs
*.g.i.cs

# Node.js
node_modules/
npm-debug.log
yarn-error.log

# Visual Studio Code
.vscode/

# Rider
.idea/
*.sln.iml
*.user
*.suo
*.userosscache
*.sln.doccache
.run/

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini

# Environment variables
.env
.env.local
.env.development
.env.test
.env.production
.env.*.local

# User-specific files
*.rsuser
*.suo
*.user
*.userosscache
*.sln.doccache

# User-specific files (MonoDevelop/Xamarin Studio)
*.userprefs

# Mono auto generated files
mono_crash.*

